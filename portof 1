<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Webkita - Solutions for Web Creation & Server</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #0a0a0a;
            color: #fff;
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* Liquid Cursor Effect */
        .liquid-cursor {
            position: fixed;
            width: 30px;
            height: 30px;
            background: radial-gradient(circle, rgba(120, 80, 255, 0.8) 0%, rgba(80, 120, 255, 0.4) 50%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transition: transform 0.1s ease;
            filter: blur(2px);
            animation: pulse 2s infinite;
        }

        .liquid-trail {
            position: fixed;
            width: 15px;
            height: 15px;
            background: rgba(180, 100, 255, 0.5);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9998;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.3); opacity: 0.5; }
        }

        /* Navigation */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 50px;
            background: rgba(10, 10, 10, 0.9);
            backdrop-filter: blur(10px);
            position: fixed;
            width: 100%;
            z-index: 100;
            border-bottom: 1px solid rgba(120, 80, 255, 0.3);
        }

        .logo {
            font-size: 28px;
            font-weight: bold;
            background: linear-gradient(135deg, #7850ff, #5078ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .nav-links {
            display: flex;
            gap: 30px;
            list-style: none;
        }

        .nav-links a {
            color: #fff;
            text-decoration: none;
            font-size: 16px;
            transition: color 0.3s;
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, #7850ff, #5078ff);
            transition: width 0.3s;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-links a:hover {
            color: #7850ff;
        }

        /* Hero Section */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 20px;
            position: relative;
            background: radial-gradient(ellipse at center, rgba(120, 80, 255, 0.15) 0%, transparent 70%);
        }

        .hero h1 {
            font-size: 60px;
            margin-bottom: 20px;
            line-height: 1.2;
        }

        .hero h1 span {
            background: linear-gradient(135deg, #7850ff, #5078ff, #7850ff);
            background-size: 200% 200%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 3s ease infinite;
        }

        @keyframes gradientShift {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        .hero p {
            font-size: 20px;
            color: #aaa;
            max-width: 600px;
            margin-bottom: 40px;
        }

        .cta-btn {
            padding: 15px 40px;
            font-size: 18px;
            background: linear-gradient(135deg, #7850ff, #5078ff);
            border: none;
            border-radius: 30px;
            color: #fff;
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
            text-decoration: none;
        }

        .cta-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(120, 80, 255, 0.4);
        }

        /* Services Section */
        .services {
            padding: 100px 50px;
            background: #0a0a0a;
        }

        .section-title {
            text-align: center;
            font-size: 40px;
            margin-bottom: 60px;
        }

        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .service-card {
            background: rgba(20, 20, 20, 0.8);
            border: 1px solid rgba(120, 80, 255, 0.2);
            border-radius: 20px;
            padding: 40px;
            text-align: center;
            transition: transform 0.3s, border-color 0.3s;
        }

        .service-card:hover {
            transform: translateY(-10px);
            border-color: #7850ff;
        }

        .service-icon {
            font-size: 50px;
            margin-bottom: 20px;
        }

        .service-card h3 {
            font-size: 24px;
            margin-bottom: 15px;
            color: #7850ff;
        }

        .service-card p {
            color: #aaa;
            line-height: 1.6;
        }

        /* Pricing Section */
        .pricing {
            padding: 100px 50px;
            background: radial-gradient(ellipse at bottom, rgba(120, 80, 255, 0.1) 0%, transparent 70%);
        }

        .pricing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 30px;
            max-width: 1000px;
            margin: 0 auto;
        }

        .price-card {
            background: rgba(20, 20, 20, 0.9);
            border: 1px solid rgba(120, 80, 255, 0.3);
            border-radius: 20px;
            padding: 40px;
            text-align: center;
            transition: transform 0.3s;
        }

        .price-card:hover {
            transform: scale(1.05);
        }

        .price-card.featured {
            border-color: #7850ff;
            box-shadow: 0 0 30px rgba(120, 80, 255, 0.3);
        }

        .price {
            font-size: 48px;
            font-weight: bold;
            margin: 20px 0;
            background: linear-gradient(135deg, #7850ff, #5078ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .price span {
            font-size: 18px;
            color: #aaa;
        }

        .price-card ul {
            list-style: none;
            margin: 20px 0;
        }

        .price-card li {
            padding: 10px 0;
            color: #ccc;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        /* Contact/Quote Section */
        .contact {
            padding: 100px 50px;
            max-width: 600px;
            margin: 0 auto;
        }

        .contact-form {
            background: rgba(20, 20, 20, 0.9);
            border: 1px solid rgba(120, 80, 255, 0.3);
            border-radius: 20px;
            padding: 40px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            margin-bottom: 8px;
            color: #ccc;
        }

        .form-group input,
        .form-group textarea,
        .form-group select {
            width: 100%;
            padding: 15px;
            background: rgba(30, 30, 30, 0.8);
            border: 1px solid rgba(120, 80, 255, 0.3);
            border-radius: 10px;
            color: #fff;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        .form-group input:focus,
        .form-group textarea:focus,
        .form-group select:focus {
            outline: none;
            border-color: #7850ff;
        }

        .form-group textarea {
            min-height: 120px;
            resize: vertical;
        }

        .submit-btn {
            width: 100%;
            padding: 15px;
            font-size: 18px;
            background: linear-gradient(135deg, #7850ff, #5078ff);
            border: none;
            border-radius: 10px;
            color: #fff;
            cursor: pointer;
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .submit-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(120, 80, 255, 0.4);
        }

        /* Footer */
        footer {
            padding: 40px 50px;
            text-align: center;
            border-top: 1px solid rgba(120, 80, 255, 0.2);
            color: #666;
        }

        /* Floating particles background */
        .particles {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: -1;
        }

        .particle {
            position: absolute;
            width: 4px;
            height: 4px;
            background: rgba(120, 80, 255, 0.5);
            border-radius: 50%;
            animation: float 10s infinite;
        }

        @keyframes float {
            0%, 100% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { transform: translateY(-100vh) rotate(720deg); opacity: 0; }
        }

        @media (max-width: 768px) {
            .hero h1 { font-size: 36px; }
            nav { padding: 15px 20px; }
            .nav-links { display: none; }
            .services, .pricing, .contact { padding: 60px 20px; }
        }
    </style>
</head>
<body>
    <!-- Liquid Cursor -->
    <div class="liquid-cursor" id="cursor"></div>
    
    <!-- Background Particles -->
    <div class="particles" id="particles"></div>

    <!-- Navigation -->
    <nav>
        <div class="logo">Webkita</div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#services">Services</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#contact">Get Quote</a></li>
        </ul>
    </nav>

    <!-- Hero Section -->
    <section class="hero" id="home">
        <h1>Welcome to <span>Webkita</span></h1>
        <p>Your complete solution for professional web creation and server management. We build stunning websites and provide reliable server solutions.</p>
        <a href="#contact" class="cta-btn">Get a Quote</a>
    </section>

    <!-- Services Section -->
    <section class="services" id="services">
        <h2 class="section-title">Our Services</h2>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">🌐</div>
                <h3>Web Creation</h3>
                <p>Professional, modern, and responsive websites tailored to your needs. From landing pages to full e-commerce solutions.</p>
            </div>
            <div class="service-card">
                <div class="service-icon">🖥️</div>
                <h3>Server Solutions</h3>
                <p>Reliable hosting and server management. We ensure your website runs fast, secure, and always online.</p>
            </div>
            <div class="service-card">
                <div class="service-icon">⚡</div>
                <h3>Web Maintenance</h3>
                <p>Keep your website updated and secure. We handle updates, backups, and technical support.</p>
            </div>
        </div>
    </section>

    <!-- Pricing Section -->
    <section class="pricing" id="pricing">
        <h2 class="section-title">Our Pricing</h2>
        <div class="pricing-grid">
            <div class="price-card">
                <h3>Basic</h3>
                <div class="price">$99<span>/project</span></div>
                <ul>
                    <li>Single Page Website</li>
                    <li>Responsive Design</li>
                    <li>Contact Form</li>
                    <li>Basic SEO</li>
                </ul>
                <a href="#contact" class="cta-btn">Order Now</a>
            </div>
            <div class="price-card featured">
                <h3>Professional</h3>
                <div class="price">$299<span>/project</span></div>
                <ul>
                    <li>Multi-page Website</li>
                    <li>Custom Design</li>
                    <li>CMS Integration</li>
                    <li>Advanced SEO</li>
                    <li>Server Setup</li>
                </ul>
                <a href="#contact" class="cta-btn">Order Now</a>
            </div>
            <div class="price-card">
                <h3>Enterprise</h3>
                <div class="price">Custom</div>
                <ul>
                    <li>E-commerce Solution</li>
                    <li>Custom Development</li>
                    <li>Dedicated Server</li>
                    <li>24/7 Support</li>
                    <li>Monthly Maintenance</li>
                </ul>
                <a href="#contact" class="cta-btn">Contact Us</a>
            </div>
        </div>
    </section>

    <!-- Contact/Quote Section -->
    <section class="contact" id="contact">
        <h2 class="section-title">Ask for Price</h2>
        <form class="contact-form" id="quoteForm">
            <div class="form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" placeholder="Enter your name" required>
            </div>
            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" placeholder="Enter your email" required>
            </div>
            <div class="form-group">
                <label for="service">Service Interested In</label>
                <select id="service" name="service" required>
                    <option value="">Select a service</option>
                    <option value="web-creation">Web Creation</option>
                    <option value="server">Server Solutions</option>
                    <option value="maintenance">Web Maintenance</option>
                    <option value="ecommerce">E-commerce</option>
                    <option value="other">Other</option>
                </select>
            </div>
            <div class="form-group">
                <label for="message">Project Details</label>
                <textarea id="message" name="message" placeholder="Describe your project requirements..." required></textarea>
            </div>
            <button type="submit" class="submit-btn">Send Quote Request</button>
        </form>
    </section>

    <!-- Footer -->
    <footer>
        <p>&copy; 2024 Webkita - Solutions for Web Creation & Server. All rights reserved.</p>
    </footer>

    <script>
        // Liquid Cursor Effect
        const cursor = document.getElementById('cursor');
        const trails = [];
        const trailCount = 8;

        // Create trail elements
        for (let i = 0; i < trailCount; i++) {
            const trail = document.createElement('div');
            trail.className = 'liquid-trail';
            trail.style.opacity = (1 - i / trailCount) * 0.5;
            trail.style.transform = `scale(${1 - i / trailCount})`;
            document.body.appendChild(trail);
            trails.push({ element: trail, x: 0, y: 0 });
        }

        let mouseX = 0, mouseY = 0;
        let currentX = 0, currentY = 0;

        document.addEventListener('mousemove', (e) => {
            mouseX = e.clientX;
            mouseY = e.clientY;
        });

        function animateCursor() {
            // Smooth follow with delay
            currentX += (mouseX - currentX) * 0.15;
            currentY += (mouseY - currentY) * 0.15;

            // Main cursor
            cursor.style.left = currentX - 15 + 'px';
            cursor.style.top = currentY - 15 + 'px';

            // Trail effect
            trails.forEach((trail, index) => {
                const delay = (index + 1) * 0.08;
                trail.x += (mouseX - trail.x) * delay * 0.3;
                trail.y += (mouseY - trail.y) * delay * 0.3;
                trail.element.style.left = trail.x - 7 + 'px';
                trail.element.style.top = trail.y - 7 + 'px';
            });

            requestAnimationFrame(animateCursor);
        }

        animateCursor();

        // Create background particles
        const particlesContainer = document.getElementById('particles');
        for (let i = 0; i < 20; i++) {
            const particle = document.createElement('div');
            particle.className = 'particle';
            particle.style.left = Math.random() * 100 + '%';
            particle.style.animationDelay = Math.random() * 10 + 's';
            particle.style.animationDuration = (10 + Math.random() * 10) + 's';
            particlesContainer.appendChild(particle);
        }

        // Form submission
        document.getElementById('quoteForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert('Thank you for your quote request! We will contact you within 24 hours.');
            this.reset();
        });

        // Hide default cursor
        document.body.style.cursor = 'none';
        
        // Show default cursor on form inputs
        document.querySelectorAll('input, textarea, select, button').forEach(el => {
            el.style.cursor = 'default';
        });
    </script>
</body>
</html>